# ══════════════════════════════════════════════════════════════
#  Qoyod Creative OS — server env
#  Copy this file to `.env` and fill in the secrets.
#  Never commit the real `.env`.
# ══════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────
# Anthropic API key (required) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Team password for the login gate
TEAM_PASSWORD=QoyodTeam2026

# Claude model (default: claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Server port (default: 8080)
PORT=8080

# Public host used to build OAuth redirect URIs (Canva, Miro callbacks).
# If unset the server falls back to the x-forwarded-host / host headers.
# Example: PUBLIC_HOST=creative.qoyod.team
PUBLIC_HOST=

# ── Google (Gemini — Nano Banana image model + text) ─────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google Drive (team asset folder) ─────────────────────────
# Option A (preferred): paste the service-account JSON as a single line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option B: path to the JSON file on disk
GOOGLE_APPLICATION_CREDENTIALS=
# The Drive folder id to upsert files into. Share the folder with the
# service-account email (Editor access).
GOOGLE_DRIVE_FOLDER_ID=

# ── Canva OAuth (optional) ───────────────────────────────────
# https://www.canva.com/developers
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# ── Miro OAuth (optional) ────────────────────────────────────
MIRO_CLIENT_ID=
MIRO_CLIENT_SECRET=
# Or a long-lived access token if you prefer to skip OAuth:
MIRO_ACCESS_TOKEN=

# ── WordPress (optional — draft landing pages) ───────────────
WP_SITE_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# ── HubSpot (optional — draft landing pages) ─────────────────
HS_ACCESS_TOKEN=

# ── Slack (optional — agent posts summaries back to channels) ─
# Bot token starting with xoxb-… Scope required: chat:write
SLACK_BOT_TOKEN=

# ── Asana (optional — agent can create & read tasks) ─────────
# Personal Access Token from https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=

# ── Figma (optional — design references shown in the UI) ────
# App screens reference
FIGMA_APP_URL=
# Marketing web pages reference
FIGMA_WEB_URL=
